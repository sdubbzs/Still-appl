# Stool Scout optional environment variables
# Copy this file to `.env.local` for local development when you want
# live photo vision to run before the conservative rules layer.

# Either variable works. Leave blank to stay on the safe prototype fallback path.
OPENAI_API_KEY=
# STOOL_SCOUT_OPENAI_API_KEY=

# Optional vision model override.
STOOL_SCOUT_VISION_MODEL=gpt-4.1-mini
